    "echarts": "^5.4.3",
    "echarts-wordcloud": "^2.1.0",
    "element-plus": "^2.2.8",
    "pinia": "^2.0.14",
    "three": "^0.161.0",
    "vue": "^3.2.37",
    "vue-router": "^4.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^22.1.0",
    "typescript": "^5.6.3",
    "unplugin-auto-import": "^0.17.5",
